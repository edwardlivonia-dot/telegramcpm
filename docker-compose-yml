version: '3.8'
services:
  bot:
    build: .
    env_file: .env
    depends_on:
      - db
  db:
    image: postgres:16
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: cpm_bot
    volumes:
      - pgdata:/var/lib/postgresql/data
volumes:
  pgdata:
