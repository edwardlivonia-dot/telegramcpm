version: '3.8'
services:
  db:
    image: postgres:15
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: cpm_bot
    volumes:
      - pgdata:/var/lib/postgresql/data
  bot:
    build:.
    depends_on:
      - db
    env_file:
      -.env
volumes:
  pgdata:
